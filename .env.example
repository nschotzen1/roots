# Leave unset for the default hybrid mode:
# - production multiplayer rooms use the bundled same-origin /api backend
# - single-player can stay client-local
# Set to / to route every API call through the bundled Vercel API.
# VITE_API_BASE_URL=/

# Shared Vercel multiplayer rooms. Vercel KV env names are also supported:
# KV_REST_API_URL / KV_REST_API_TOKEN.
# ROOMS_BACKEND=redis
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional backend root source overrides. Defaults already load both languages.
# HEBREW_ROOTS_SOURCE_FILE=backend/data/roots_hebrew_scraped.txt
# ARABIC_ROOTS_SOURCE_FILE=backend/data/roots_arabic_scraped.txt
